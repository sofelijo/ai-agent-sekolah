# ============================================
# WhatsApp Cloud API Configuration
# ============================================
# Get from: https://developers.facebook.com/
# WhatsApp → API Setup

# Access Token (24hrs temporary or permanent from System User)
WA_ASKA_ACCESS_TOKEN=your_whatsapp_access_token_here

# Phone Number ID
WA_ASKA_PHONE_NUMBER_ID=your_phone_number_id_here

# Verify Token (buat sendiri, untuk webhook verification)
WA_ASKA_VERIFY_TOKEN=aska_bot_verify_token_123

# ============================================
# Google Drive Configuration
# ============================================
# Get from: https://drive.google.com/
# Buka folder, copy ID dari URL

# Default folder ID untuk menyimpan file
WA_ASKA_GDRIVE_FOLDER_ID=your_google_drive_folder_id_here

# ============================================
# Gemini AI Configuration
# ============================================
# Get from: https://aistudio.google.com/
# Free tier: 15 RPM, 1500 requests/day

# Gemini API Key
WA_ASKA_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Server Configuration (Optional)
# ============================================

# Debug mode (true/false)
WA_ASKA_DEBUG=true

# Server port
WA_ASKA_PORT=8000

# Server host
WA_ASKA_HOST=0.0.0.0

# WhatsApp API version
WA_ASKA_API_VERSION=v17.0

# ============================================
# PDF Processing (Optional)
# ============================================

# Maximum characters to extract from PDF
WA_ASKA_PDF_MAX_TEXT=2000

# DPI for PDF to image rendering
WA_ASKA_PDF_DPI=150

# ============================================
# Message Cache (Optional)
# ============================================

# Cache TTL in hours (untuk simpan context PDF + command)
WA_ASKA_CACHE_TTL=24
